{
  "info": {
    "name": "ChainBois API - Phase 5: Armory + Points",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://test-2.ghettopigeon.com/api/v1"
    },
    {
      "key": "userAddress",
      "value": "0xYOUR_WALLET_ADDRESS"
    }
  ],
  "item": [
    {
      "name": "Armory",
      "item": [
        {
          "name": "List All Weapons",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/weapons",
            "description": "List available weapons grouped by category"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"assault\": [\n      {\n        \"tokenId\": 1,\n        \"weaponName\": \"AR M4 MK18\",\n        \"category\": \"assault\",\n        \"tier\": \"base\",\n        \"price\": 1,\n        \"imageUri\": \"\",\n        \"contractAddress\": \"0xa2AFf3105668124A187b1212Ab850bf8b98dD07d\",\n        \"metadataUri\": \"https://test-2.ghettopigeon.com/api/v1/metadata/weapon/1.json\"\n      }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "List Weapons by Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/weapons/assault",
            "description": "List weapons in a specific category"
          }
        },
        {
          "name": "Weapon Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/weapon/1",
            "description": "Get weapon details + payment address"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"tokenId\": 1,\n    \"weaponName\": \"AR M4 MK18\",\n    \"category\": \"assault\",\n    \"tier\": \"base\",\n    \"price\": 1,\n    \"currency\": \"BATTLE\",\n    \"available\": true,\n    \"description\": \"\",\n    \"imageUri\": \"\",\n    \"contractAddress\": \"0xa2AFf3105668124A187b1212Ab850bf8b98dD07d\",\n    \"metadataUri\": \"https://test-2.ghettopigeon.com/api/v1/metadata/weapon/1.json\",\n    \"paymentAddress\": \"0xD40e6631617B7557C28789bAc01648A74753739C\"\n  }\n}"
            }
          ]
        },
        {
          "name": "List ChainBoi NFTs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/nfts",
            "description": "List ChainBoi NFTs available for purchase"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"nfts\": [\n      {\n        \"tokenId\": 5,\n        \"level\": 0,\n        \"badge\": \"private\",\n        \"imageUri\": \"\",\n        \"contractAddress\": \"0xB2FDDb56D85073BCBE245D46dbC1BE4D4541305b\",\n        \"metadataUri\": \"https://test-2.ghettopigeon.com/api/v1/metadata/5.json\",\n        \"traits\": []\n      }\n    ],\n    \"price\": 0.001,\n    \"currency\": \"AVAX\",\n    \"available\": 45,\n    \"paymentAddress\": \"0x469622d0FB5ED43B2e7C45E98D355F2cf03816a0\"\n  }\n}"
            }
          ]
        },
        {
          "name": "ChainBoi NFT Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/nft/1",
            "description": "Single NFT details + payment address"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"tokenId\": 5,\n    \"level\": 0,\n    \"badge\": \"private\",\n    \"traits\": [{\"trait_type\": \"Background\", \"value\": \"Combat Red\"}],\n    \"imageUri\": \"\",\n    \"contractAddress\": \"0xB2FDDb56D85073BCBE245D46dbC1BE4D4541305b\",\n    \"metadataUri\": \"https://test-2.ghettopigeon.com/api/v1/metadata/5.json\",\n    \"price\": 0.001,\n    \"currency\": \"AVAX\",\n    \"available\": true,\n    \"paymentAddress\": \"0x469622d0FB5ED43B2e7C45E98D355F2cf03816a0\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Purchase Weapon",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/armory/purchase/weapon",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{userAddress}}\",\n  \"weaponName\": \"AR M4 MK18\",\n  \"txHash\": \"0xYOUR_PAYMENT_TX_HASH\"\n}"
            },
            "description": "Submit $BATTLE payment tx to purchase a weapon. Send $BATTLE to the paymentAddress first."
          }
        },
        {
          "name": "Purchase ChainBoi NFT",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/armory/purchase/nft",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{userAddress}}\",\n  \"txHash\": \"0xYOUR_PAYMENT_TX_HASH\",\n  \"tokenId\": 5\n}"
            },
            "description": "Submit AVAX payment tx to purchase a ChainBoi NFT. Send AVAX to the paymentAddress first. tokenId is optional."
          }
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/balance/{{userAddress}}",
            "description": "Get points + $BATTLE balance for a wallet"
          }
        }
      ]
    },
    {
      "name": "Points",
      "item": [
        {
          "name": "Get Points Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/points/{{userAddress}}",
            "description": "Get points balance and conversion info"
          }
        },
        {
          "name": "Convert Points to $BATTLE",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/points/convert",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{userAddress}}\",\n  \"amount\": 100\n}"
            },
            "description": "Convert points to $BATTLE tokens (dynamic rate based on rewards pool health tier)"
          }
        },
        {
          "name": "Points History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/points/history/{{userAddress}}?page=1&limit=20",
            "description": "View points conversion and purchase history"
          }
        }
      ]
    }
  ]
}
