{
  "info": {
    "name": "ChainBois API - Phase 5: Armory + Points",
    "description": "## Getting a Token for Authenticated Endpoints\nUse the Phase 1 Simulate Login endpoint: `POST /auth/simulate` with `{\"email\": \"your@email.com\"}` (no auth required). See docs/POSTMAN_TESTING_GUIDE.md for full instructions.\n\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://test-2.ghettopigeon.com/api/v1"
    },
    {
      "key": "userAddress",
      "value": "0xYOUR_WALLET_ADDRESS"
    }
  ],
  "item": [
    {
      "name": "Armory",
      "item": [
        {
          "name": "List All Weapons",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/weapons",
            "description": "List available weapons grouped by category"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/armory/weapons"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"assault\":[{\"tokenId\":74,\"weaponName\":\"AR M4 MK18\",\"category\":\"assault\",\"price\":0,\"blueprintTier\":\"base\",\"imageUri\":\"ipfs://...\"}],\"smg\":[],\"shotgun\":[],\"sniper\":[],\"pistol\":[],\"melee\":[],\"launcher\":[],\"special\":[]}}"
            }
          ]
        },
        {
          "name": "List Weapons by Category",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/weapons/assault",
            "description": "List weapons in a specific category"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/armory/weapons/assault"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":[{\"tokenId\":74,\"weaponName\":\"AR M4 MK18\",\"category\":\"assault\",\"price\":0,\"blueprintTier\":\"base\",\"imageUri\":\"ipfs://...\"}]}"
            }
          ]
        },
        {
          "name": "Weapon Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/weapon/1",
            "description": "Get weapon details + payment address"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/armory/weapon/1"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"tokenId\":1,\"weaponName\":\"AR M4 MK18\",\"category\":\"assault\",\"tier\":\"base\",\"price\":1,\"currency\":\"BATTLE\",\"available\":true,\"description\":\"\",\"imageUri\":\"\",\"contractAddress\":\"0xa2AFf3105668124A187b1212Ab850bf8b98dD07d\",\"metadataUri\":\"https://test-2.ghettopigeon.com/api/v1/metadata/weapon/1.json\",\"paymentAddress\":\"0xD40e6631617B7557C28789bAc01648A74753739C\"}}"
            }
          ]
        },
        {
          "name": "List ChainBoi NFTs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/nfts",
            "description": "List ChainBoi NFTs available for purchase"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/armory/nfts"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"nfts\":[{\"tokenId\":5,\"level\":0,\"badge\":\"private\",\"imageUri\":\"ipfs://bafybeifd4wjgbvnpf7kmcrkjxp7i4ipz3w2aag3elgfj6v364y2meq6ep4/5.png\",\"contractAddress\":\"0xB2FDDb56D85073BCBE245D46dbC1BE4D4541305b\",\"metadataUri\":\"https://test-2.ghettopigeon.com/api/v1/metadata/5.json\",\"traits\":[{\"trait_type\":\"Background\",\"value\":\"Combat Red\"},{\"trait_type\":\"Skin\",\"value\":\"Pale Recruit\"},{\"trait_type\":\"Weapon\",\"value\":\"War Bow\"},{\"trait_type\":\"Suit\",\"value\":\"Covert Ops Carbon Suit\"},{\"trait_type\":\"Eyes\",\"value\":\"Battle Hardened\"},{\"trait_type\":\"Mouth\",\"value\":\"Viking Beard\"},{\"trait_type\":\"Helmet\",\"value\":\"Cryo Enforcer\"},{\"trait_type\":\"Level\",\"value\":0},{\"trait_type\":\"Rank\",\"value\":\"Private\"},{\"trait_type\":\"Kills\",\"value\":0},{\"trait_type\":\"Score\",\"value\":0},{\"trait_type\":\"Games Played\",\"value\":0}]}],\"nftPrice\":0.001}}"
            }
          ]
        },
        {
          "name": "ChainBoi NFT Detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/nft/19",
            "description": "Single NFT details + payment address"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/armory/nft/19"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"tokenId\":19,\"contractAddress\":\"0xB2FDDb56D85073BCBE245D46dbC1BE4D4541305b\",\"level\":0,\"badge\":\"trainee\",\"traits\":[],\"imageUri\":\"ipfs://...\",\"metadataUri\":\"ipfs://...\",\"price\":0.001,\"currency\":\"AVAX\",\"available\":true,\"paymentAddress\":\"0x469622d0fb5ed43b2e7c45e98d355f2cf03816a0\"}}"
            }
          ]
        },
        {
          "name": "Purchase Weapon",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/armory/purchase/weapon",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{userAddress}}\",\n  \"weaponName\": \"AR M4 MK18\",\n  \"txHash\": \"0xYOUR_PAYMENT_TX_HASH\"\n}"
            },
            "description": "Submit $BATTLE payment tx to purchase a weapon. Send $BATTLE to the paymentAddress first."
          }
        },
        {
          "name": "Purchase ChainBoi NFT",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/armory/purchase/nft",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{userAddress}}\",\n  \"txHash\": \"0xYOUR_PAYMENT_TX_HASH\",\n  \"tokenId\": 5\n}"
            },
            "description": "Submit AVAX payment tx to purchase a ChainBoi NFT. Send AVAX to the paymentAddress first. tokenId is optional."
          }
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/armory/balance/{{userAddress}}",
            "description": "Get points + $BATTLE balance for a wallet"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/armory/balance/0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"address\":\"0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566\",\"pointsBalance\":4800,\"battleBalance\":1000,\"battleBalanceRaw\":\"1000.0\"}}"
            }
          ]
        }
      ]
    },
    {
      "name": "Points",
      "item": [
        {
          "name": "Get Points Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/points/{{userAddress}}",
            "description": "Get points balance and conversion info"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/points/0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"address\":\"0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566\",\"pointsBalance\":4800,\"conversionRate\":1,\"maxConvertible\":4800}}"
            }
          ]
        },
        {
          "name": "Convert Points to $BATTLE",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/points/convert",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566\",\n  \"amount\": 100\n}"
            },
            "description": "Convert points to $BATTLE tokens (dynamic rate based on rewards pool health tier)"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "POST",
                "url": "{{baseUrl}}/points/convert",
                "header": [
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"address\":\"0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566\",\"amount\":100}"
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"message\":\"Converted 100 points to 100 $BATTLE\",\"pointsDeducted\":100,\"battleTokensReceived\":100,\"conversionRate\":1,\"newPointsBalance\":4700,\"txHash\":\"0xfd068d...\"}}"
            }
          ]
        },
        {
          "name": "Points History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/points/history/{{userAddress}}?page=1&limit=20",
            "description": "View points conversion and purchase history"
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "url": "{{baseUrl}}/points/history/0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566?page=1&limit=20"
              },
              "status": "OK",
              "code": 200,
              "body": "{\"success\":true,\"data\":{\"history\":[{\"type\":\"points_conversion\",\"amount\":100,\"currency\":\"BATTLE\",\"txHash\":\"0xfd068d...\",\"status\":\"confirmed\",\"metadata\":{\"description\":\"Converted 100 points to 100 BATTLE tokens (rate: 1).\",\"pointsDeducted\":100,\"battleReceived\":100,\"conversionRate\":1}}]}}"
            }
          ]
        }
      ]
    }
  ]
}