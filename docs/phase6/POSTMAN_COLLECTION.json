{
  "info": {
    "name": "ChainBois API - Phase 6: Inventory",
    "description": "## Getting a Token for Authenticated Endpoints\nUse the Phase 1 Simulate Login endpoint: `POST /auth/simulate` with `{\"email\": \"your@email.com\"}` (no auth required). See docs/POSTMAN_TESTING_GUIDE.md for full instructions.\n\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://test-2.ghettopigeon.com/api/v1"
    },
    {
      "key": "userAddress",
      "value": "0xYOUR_WALLET_ADDRESS"
    }
  ],
  "item": [
    {
      "name": "Full Inventory",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventory/{{userAddress}}",
        "description": "Get all owned assets: ChainBoi NFTs, weapons, balances"
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"username\": \"ghettopigeons\",\n      \"address\": \"0x4af91587d9d2bc5439ec3ff3cf49e85c52a40566\",\n      \"pointsBalance\": 4700,\n      \"score\": 4800,\n      \"highScore\": 4800,\n      \"level\": 0,\n      \"hasNft\": true\n    },\n    \"nfts\": [\n      {\n        \"tokenId\": 3,\n        \"level\": 0,\n        \"rank\": \"Private\"\n      }\n    ],\n    \"weapons\": [\n      {\n        \"weaponName\": \"Sawed-Off Shotgun\",\n        \"category\": \"shotgun\"\n      },\n      {\n        \"weaponName\": \"AK74M\",\n        \"category\": \"assault\"\n      }\n    ]\n  }\n}"
        }
      ]
    },
    {
      "name": "ChainBoi NFTs Only",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventory/{{userAddress}}/nfts",
        "description": "List only ChainBoi NFTs owned by this wallet"
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"tokenId\": 3,\n      \"level\": 0,\n      \"rank\": \"Private\",\n      \"badge\": \"trainee\",\n      \"imageUri\": \"ipfs://bafybeifd4w.../3.png\",\n      \"traits\": [\n        {\n          \"trait_type\": \"Background\",\n          \"value\": \"Hellfire Abstract\"\n        }\n      ]\n    }\n  ]\n}"
        }
      ]
    },
    {
      "name": "Weapons Only",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventory/{{userAddress}}/weapons",
        "description": "List only weapon NFTs owned by this wallet"
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"tokenId\": 6,\n      \"weaponName\": \"Sawed-Off Shotgun\",\n      \"category\": \"shotgun\",\n      \"tier\": \"base\",\n      \"imageUri\": \"ipfs://bafybeigabw.../06-Sawed-Off-Shotgun.jpeg\"\n    }\n  ]\n}"
        }
      ]
    },
    {
      "name": "Transaction History",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/inventory/{{userAddress}}/history?page=1&limit=20",
        "description": "View all transaction history for this wallet. Optional filter: ?type=weapon_purchase"
      },
      "response": [
        {
          "name": "Success",
          "status": "OK",
          "code": 200,
          "body": "{\n  \"success\": true,\n  \"data\": {\n    \"history\": [\n      {\n        \"type\": \"points_conversion\",\n        \"amount\": 100,\n        \"currency\": \"BATTLE\",\n        \"txHash\": \"0xfd068d...\",\n        \"status\": \"confirmed\"\n      }\n    ],\n    \"currentPage\": 1,\n    \"totalPages\": 1\n  }\n}"
        }
      ]
    }
  ]
}