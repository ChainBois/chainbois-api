{
  "info": {
    "name": "ChainBois API v1",
    "description": "ChainBois Gaming NFT Platform API - Avalanche C-Chain\n\nSet the `base_url` and `firebase_token` variables before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "firebase_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_address",
      "value": "0x0000000000000000000000000000000000000000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@chainbois.com\",\n  \"password\": \"testpassword123\",\n  \"username\": \"TestPlayer1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/create-user",
              "host": ["{{base_url}}"],
              "path": ["auth", "create-user"]
            },
            "description": "Create a new Firebase Auth user and write initial data to Firebase RTDB.\n\nNo auth token required."
          },
          "response": [
            {
              "name": "Success",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"uid\": \"abc123def456\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{firebase_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"{{test_address}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with Firebase Auth token + wallet address.\n\nChecks on-chain NFT ownership, syncs assets to Firebase for Unity game.\nAuto-upgrades WEB2→WEB3 when NFT detected, auto-downgrades when lost."
          },
          "response": [
            {
              "name": "Success (Web3 User)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"uid\": \"abc123\",\n      \"username\": \"TestPlayer1\",\n      \"address\": \"0x...\",\n      \"playerType\": \"web3\",\n      \"pointsBalance\": 500,\n      \"battleTokenBalance\": 0,\n      \"level\": 2,\n      \"score\": 1500,\n      \"highScore\": 1500,\n      \"gamesPlayed\": 10,\n      \"hasNft\": true,\n      \"nftTokenId\": 42,\n      \"isBanned\": false,\n      \"hasClaimed\": false,\n      \"lastLogin\": \"2026-03-03T12:00:00.000Z\"\n    },\n    \"assets\": {\n      \"hasNft\": true,\n      \"nftTokenId\": 42,\n      \"level\": 2\n    },\n    \"weapons\": [\n      { \"tokenId\": 1, \"name\": \"AK-47\" }\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{firebase_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            },
            "description": "Get the authenticated user's profile.\n\nReturns user data from MongoDB (not re-fetched from chain)."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"user\": {\n      \"uid\": \"abc123\",\n      \"username\": \"TestPlayer1\",\n      \"address\": \"0x...\",\n      \"playerType\": \"web3\",\n      \"pointsBalance\": 500,\n      \"battleTokenBalance\": 0,\n      \"level\": 2,\n      \"score\": 1500,\n      \"highScore\": 1500,\n      \"gamesPlayed\": 10,\n      \"hasNft\": true,\n      \"nftTokenId\": 42,\n      \"isBanned\": false,\n      \"hasClaimed\": false,\n      \"lastLogin\": \"2026-03-03T12:00:00.000Z\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{firebase_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout: revokes Firebase refresh tokens and clears game data in Firebase RTDB."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Logged out successfully\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Game",
      "item": [
        {
          "name": "Verify Assets",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{firebase_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/game/verify-assets",
              "host": ["{{base_url}}"],
              "path": ["game", "verify-assets"]
            },
            "description": "Re-fetch NFT ownership from on-chain and update MongoDB + Firebase.\n\nUse this to refresh asset data without re-logging in."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"hasNft\": true,\n    \"nftTokenId\": 42,\n    \"level\": 2,\n    \"ownedWeaponNfts\": [{\"name\": \"AK-47\", \"tokenId\": 1}],\n    \"characters\": [\"Recruit_A\", \"Recruit_B\", \"Recruit_C\", \"Recruit_D\"],\n    \"baseWeapons\": [\"Pistol\", \"Knife\", \"Shotgun\", \"SMG\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Set Avatar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{firebase_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tokenId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/game/set-avatar",
              "host": ["{{base_url}}"],
              "path": ["game", "set-avatar"]
            },
            "description": "Set the user's active ChainBoi NFT.\n\nVerifies on-chain that the user owns the specified tokenId."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"tokenId\": 1,\n    \"level\": 0,\n    \"characters\": [\"Recruit_A\", \"Recruit_B\", \"Recruit_C\", \"Recruit_D\"],\n    \"baseWeapons\": [\"Pistol\", \"Knife\", \"Shotgun\", \"SMG\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Characters",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{firebase_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/game/characters/{{test_address}}",
              "host": ["{{base_url}}"],
              "path": ["game", "characters", "{{test_address}}"]
            },
            "description": "Get unlocked characters and weapons for a given address.\n\nBOLA-protected: authenticated user can only query their own address."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"level\": 2,\n    \"characters\": [\"Recruit_A\", \"Recruit_B\", \"Recruit_C\", \"Recruit_D\", \"Soldier_A\", \"Soldier_B\", \"Soldier_C\", \"Soldier_D\", \"Veteran_A\", \"Veteran_B\", \"Veteran_C\", \"Veteran_D\"],\n    \"baseWeapons\": [\"Pistol\", \"Knife\", \"Shotgun\", \"SMG\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Download Game (Win)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/game/download/win",
              "host": ["{{base_url}}"],
              "path": ["game", "download", "win"]
            },
            "description": "Download the Windows game build.\n\nNo auth required. Streams the zip file."
          }
        },
        {
          "name": "Download Game (Mac)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/game/download/mac",
              "host": ["{{base_url}}"],
              "path": ["game", "download", "mac"]
            },
            "description": "Download the macOS game build.\n\nNo auth required. Streams the zip file."
          }
        },
        {
          "name": "Get Game Info",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/game/info",
              "host": ["{{base_url}}"],
              "path": ["game", "info"]
            },
            "description": "Get game download count, trailer URL, and platform availability.\n\nNo auth required."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"downloads\": 150,\n    \"trailer\": \"https://youtube.com/...\",\n    \"platforms\": {\n      \"win\": true,\n      \"mac\": false\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Health & Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/settings",
              "host": ["{{base_url}}"],
              "path": ["settings"]
            },
            "description": "Get public game settings (costs, thresholds, etc.).\n\nNo auth required. The contracts field is excluded for security."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"tournamentSchedule\": { \"startDay\": 3, \"startHour\": 12, \"durationHours\": 120, \"cooldownHours\": 48 },\n    \"prizePools\": { \"1\": 2, \"2\": 4, \"3\": 6, \"4\": 8, \"5\": 10, \"6\": 12, \"7\": 14 },\n    \"levelUpCost\": 1,\n    \"maxPointsPerMatch\": 5000,\n    \"burnRate\": 0.5,\n    \"teamRevenueSplit\": 0.25,\n    \"awardPoolSplit\": 0.75,\n    \"armoryClosedDuringCooldown\": true,\n    \"claimLimit\": 1,\n    \"claimEnabled\": true,\n    \"downloads\": 150,\n    \"trailer\": \"https://youtube.com/...\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Check API and MongoDB status."
          },
          "response": [
            {
              "name": "Healthy",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"status\": \"ok\",\n    \"uptime\": 12345,\n    \"timestamp\": \"2026-03-03T12:00:00.000Z\",\n    \"services\": {\n      \"mongodb\": \"connected\"\n    }\n  }\n}"
            }
          ]
        }
      ]
    }
  ]
}
