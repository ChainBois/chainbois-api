    "nft",
    "gaming",
    "web3"
  ],
  "author": "Apostrophe Corp",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.7.0",
    "form-data": "^4.0.5",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.0",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pinata": "^2.5.5",
    "socket.io": "^4.8.0",
    "validator": "^13.12.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "hardhat": "^2.28.6",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/reference-projects-from-algorand/"
