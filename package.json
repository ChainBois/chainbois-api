{
  "name": "chainbois-api",
  "version": "1.0.0",
  "description": "ChainBois Gaming NFT Platform API - Avalanche C-Chain",
  "main": "server.js",
  "engines": {
    "node": ">=18",
    "npm": ">=10"
  },
  "scripts": {
    "start:dev": "nodemon server.js",
    "start": "pm2 start ecosystem.config.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles"
  },
  "keywords": [
    "chainbois",
